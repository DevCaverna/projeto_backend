<h1>Minhas Habilidades</h1>
<a
  href="/aluno/habilidades/adicionar"
  class="btn btn-success"
  style="margin-bottom: 16px;"
>+ Adicionar Habilidade</a>

<table>
  <thead>
    <tr>
      <th>Habilidade</th>
      <th>Nível</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    {{#each habilidades}}
      <tr>
        <td>{{this.nome}}</td>
        <td>{{this.AlunoHabilidade.nivel}}</td>
        <td class="acoes">
          <a
            href="/aluno/habilidades/editar/{{this.id}}"
            class="btn btn-primary"
          >Editar Nível</a>
          <form
            method="POST"
            action="/aluno/habilidades/remover/{{this.id}}"
            style="display:inline;"
          >
            <button
              type="submit"
              class="btn btn-danger"
              onclick="return confirm('Remover habilidade?')"
            >Remover</button>
          </form>
        </td>
      </tr>
    {{else}}
      <tr><td colspan="3">Nenhuma habilidade adicionada.</td></tr>
    {{/each}}
  </tbody>
</table>