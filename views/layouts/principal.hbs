<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sistema de Receitas</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #f5f5f5; color: #333; }
    nav { background: #2c3e50; padding: 12px 24px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    nav a { color: #ecf0f1; text-decoration: none; font-size: 14px; }
    nav a:hover { text-decoration: underline; }
    nav .marca { font-weight: bold; font-size: 18px; margin-right: auto; }
    .container { max-width: 960px; margin: 30px auto; padding: 0 20px; }
    h1, h2 { margin-bottom: 20px; color: #2c3e50; }
    table { width: 100%; border-collapse: collapse; background: #fff; margin-bottom: 20px; }
    th, td { padding: 10px 14px; text-align: left; border-bottom: 1px solid #ddd; }
    th { background: #2c3e50; color: #fff; }
    form { background: #fff; padding: 24px; border-radius: 6px; margin-bottom: 20px; }
    label { display: block; margin-bottom: 6px; font-weight: 600; }
    input[type="text"], input[type="email"], input[type="password"], input[type="number"],
    select, textarea { width: 100%; padding: 8px 12px; margin-bottom: 16px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; }
    textarea { resize: vertical; min-height: 80px; }
    select[multiple] { height: 120px; }
    .btn { display: inline-block; padding: 8px 18px; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; text-decoration: none; color: #fff; }
    .btn-primary { background: #2980b9; }
    .btn-danger { background: #c0392b; }
    .btn-success { background: #27ae60; }
    .btn:hover { opacity: 0.9; }
    .acoes { display: flex; gap: 8px; }
    .erro { background: #e74c3c; color: #fff; padding: 10px; border-radius: 4px; margin-bottom: 16px; }
    .card { background: #fff; padding: 18px; border-radius: 6px; margin-bottom: 14px; border-left: 4px solid #2980b9; }
    .card h3 { margin-bottom: 6px; }
    .card p { font-size: 14px; color: #555; }
    .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
    .tag { background: #ecf0f1; padding: 3px 10px; border-radius: 12px; font-size: 12px; }
  </style>
</head>
<body>
  {{> navbar}}
  <div class="container">
    {{{body}}}
  </div>
</body>
</html>
