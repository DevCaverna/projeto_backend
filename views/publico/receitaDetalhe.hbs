<div class="recipe-header">
    <h1>{{receita.nome}}</h1>
    <div class="tags" style="justify-content: center;">
        {{#each receita.categorias}}
            <span class="tag" style="font-size: 0.9rem; padding: 6px 15px;">{{nome}}</span>
        {{/each}}
    </div>
</div>

<div class="recipe-info-card">
    <h3>Descrição</h3>
    <p style="margin-bottom: 25px; font-size: 1.1rem;">{{receita.descricao}}</p>

    {{#if receita.link_externo}}
        <p style="margin-bottom: 25px;">
            <a href="{{receita.link_externo}}" target="_blank" class="btn btn-primary">Acessar Receita Original</a>
        </p>
    {{/if}}

    <h5 class="mt-4">Alunos Colaboradores:</h5>
    <div class="tags">
        {{#each receita.alunos}}
            <span class="tag aluno" style="font-size: 0.9rem; padding: 6px 15px;">{{nome}}</span>
        {{/each}}
    </div>
</div>

<div class="comments-section">
    <h2 style="margin-bottom: 30px; border-bottom: 2px solid var(--primary-color); display: inline-block; padding-bottom: 5px;">
        Comentários ({{comentarios.length}})
    </h2>

    {{! Lista de Comentários }}
    <div style="margin-bottom: 50px;">
        {{#each comentarios}}
            <div class="comment-bubble">
                <div class="comment-header">
                    <span class="comment-author">{{autor.nome}}</span>
                    <span>{{formatDate dataCriacao}}</span>
                </div>
                <p style="color: var(--text-color);">{{texto}}</p>
            </div>
        {{else}}
            <p style="color: var(--text-muted); font-style: italic;">Seja o primeiro a comentar nesta receita!</p>
        {{/each}}
    </div>

    {{! Formulário de Comentários }}
    <div style="max-width: 600px;">
        <h3 style="margin-bottom: 20px;">Adicionar Comentário</h3>
        {{#if usuario}}
            <form action="/receitas/{{receita.id}}/comentarios" method="POST" class="comment-form">
                <div class="form-group">
                    <textarea class="form-control" name="texto" rows="4" placeholder="O que você achou desta receita?" required></textarea>
                </div>
                <button type="submit" class="btn btn-success">Publicar Comentário</button>
            </form>
        {{else}}
            <div style="background: rgba(44, 62, 80, 0.05); padding: 20px; border-radius: 10px; border: 1px dashed var(--secondary-color);">
                <p>Você precisa estar logado para comentar. <a href="/login" style="color: var(--primary-color); font-weight: 600;">Faça login aqui</a>.</p>
            </div>
        {{/if}}
    </div>
</div>

<div style="margin-top: 40px;">
    <a href="/" class="btn btn-secondary">← Voltar para a lista</a>
</div>
