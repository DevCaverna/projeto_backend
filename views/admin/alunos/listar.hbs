<h1>Alunos</h1>
<a
	href="/admin/alunos/cadastrar"
	class="btn btn-success"
	style="margin-bottom: 16px;"
>+ Novo Aluno</a>

<table>
	<thead>
		<tr>
			<th>ID</th>
			<th>Nome</th>
			<th>E-mail</th>
			<th>Ações</th>
		</tr>
	</thead>
	<tbody>
		{{#each alunos}}
			<tr>
				<td>{{this.id}}</td>
				<td>{{this.nome}}</td>
				<td>{{this.email}}</td>
				<td class="acoes">
					<form
						method="POST"
						action="/admin/alunos/excluir/{{this.id}}"
						class="inline-form"
					>
						<a
							href="/admin/alunos/editar/{{this.id}}"
							class="btn btn-primary"
						>Editar</a>
						<button
							type="submit"
							class="btn btn-danger"
							onclick="return confirm('Confirma exclusão?')"
						>Excluir</button>
					</form>
				</td>
			</tr>
		{{else}}
			<tr><td colspan="4">Nenhum aluno cadastrado.</td></tr>
		{{/each}}
	</tbody>
</table>
