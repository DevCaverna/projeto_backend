<h1>Editar Aluno</h1>

{{#if erro}}
  <div class="erro">{{erro}}</div>
{{/if}}

<form method="POST" action="/admin/alunos/editar/{{aluno.id}}">
  <label for="nome">Nome</label>
  <input type="text" id="nome" name="nome" value="{{aluno.nome}}" required>

  <label for="email">E-mail</label>
  <input type="email" id="email" name="email" value="{{aluno.email}}" required>

  <label for="senha">Nova Senha (deixe em branco para manter)</label>
  <input type="password" id="senha" name="senha">

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a href="/admin/alunos" class="btn btn-secondary">Cancelar</a>
  </div>
</form>
